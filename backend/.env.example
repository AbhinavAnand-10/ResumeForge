# ── LLM Providers (use one or both) ──────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Primary model: "openai" | "anthropic"
LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Web Search (choose one) ───────────────────────────────────────────
EXA_API_KEY=exa-...
SERPER_API_KEY=...

# "exa" | "serper"
SEARCH_PROVIDER=exa

# ── App Settings ──────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
ALLOWED_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO

# ── Optional: Supabase (for saving user history) ─────────────────────
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_KEY=eyJ...
